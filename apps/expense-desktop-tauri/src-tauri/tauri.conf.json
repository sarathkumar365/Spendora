{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spendora Desktop",
  "version": "0.1.0",
  "identifier": "com.spendora.desktop",
  "build": {
    "beforeDevCommand": "cd ../.. && npm run ui:dev",
    "beforeBuildCommand": "cd ../.. && npm run ui:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../expense-desktop-ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Spendora",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
