# Optional explicit path to Rust services workspace for Tauri process manager
EXPENSE_RS_ROOT=services/expense-rs

# Optional Rust logging filters
RUST_LOG=api=info,worker=info

# CORS allowlist for API (comma-separated).
# Defaults in code are local dev safe:
# - http://127.0.0.1:1420
# - http://localhost:1420
# Add known web domains in non-local environments.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:1420,http://localhost:1420,https://app.example.com
# Optional CORS overrides (safe defaults are used if omitted)
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Managed extraction provider keys (Step 2.1)
LLAMAPARSE_API_KEY=
OPENROUTER_API_KEY=

# Step 1 extraction runtime contract (required at API/worker startup)
LLAMA_CLOUD_API_KEY=
LLAMA_AGENT_NAME=spendora-statement-agent
LLAMA_SCHEMA_VERSION=statement_v1
# Optional scoping values
# LLAMA_CLOUD_ORGANIZATION_ID=
# LLAMA_CLOUD_PROJECT_ID=
# Managed flow router: `new` (Jobs) or `legacy` (current parse-first flow)
EXTRACTION_MANAGED_FLOW_MODE=new

# Optional provider overrides
LLAMAPARSE_ENDPOINT=https://api.cloud.llamaindex.ai/api/v1/parsing/upload
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4o-mini

# Extraction logging controls
# Dev default: enabled for provider troubleshooting; disable before production hardening.
EXTRACTION_LOG_FULL_RESPONSE=true
EXTRACTION_LOG_MAX_BYTES=262144
# EXPENSE_EXTRACTION_LOG_PATH=services/expense-rs/.runtime/logs/extraction-provider.log
# Common raw external API response log (all outbound provider/bootstrap/jobs HTTP responses)
# EXPENSE_EXTERNAL_API_RAW_LOG_PATH=services/expense-rs/.runtime/logs/external-api-raw.log
